# Strava — ใช้ดึงกิจกรรม Zwift (Zwift sync ไป Strava อัตโนมัติ)
# สร้างแอpp ที่ https://www.strava.com/settings/api
# Authorization Callback Domain: โดเมนที่ deploy (เช่น your-app.vercel.app)
VITE_STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret

# เปิดใช้งาน Google Vision API สำหรับการวิเคราะห์ภาพอาหารที่แม่นยำขึ้น
VITE_USE_GOOGLE_VISION=true
VITE_GOOGLE_VISION_API_KEY=YOUR_GOOGLE_VISION_API_KEY

# ถ้าต้องการใช้ API กลางของตัวเองแทน ให้ตั้งค่า URL และคีย์แทน
# VITE_IMAGE_API_URL=https://your-image-api.example.com/analyze
# VITE_IMAGE_API_KEY=your_api_key_here
